<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Notifications ───────────────────────────────────── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Exact alarms ──────────────────────────────────────────────────── -->
    <!--
        USE_EXACT_ALARM (Android 13+): granted automatically, no runtime prompt needed.
        SCHEDULE_EXACT_ALARM (Android 12): shown in system settings; we redirect the
        user there from the in-app permission settings button.
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        tools:ignore="ExactAlarm" />

    <!-- ── Boot (to reschedule alarms after reboot) ───────────────────────── -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />


    <application
        android:name=".FlowStateApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/new_ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/new_ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FlowState">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.App.Starting"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Fires the notification when the alarm triggers -->
        <receiver
            android:name=".core.notifications.ReminderReceiver"
            android:exported="false" />

        <!-- Reprograms alarms after device reboot -->
        <receiver
            android:name=".core.notifications.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- Some HTC / fast-boot devices use this action instead -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>

</manifest>